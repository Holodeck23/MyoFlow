{
  "name": "myoflow",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:run": "turbo test:run",
    "test:coverage": "turbo test:coverage",
    "test:watch": "turbo test:watch",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prisma:migrate:dev": "pnpm --filter db prisma migrate dev",
    "prisma:generate": "pnpm --filter db prisma generate",
    "prisma:studio": "pnpm --filter db prisma studio",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down",
    "db:test": "docker compose -f infra/docker/docker-compose.yml up -d && sleep 5 && export DATABASE_URL=postgresql://postgres:password@localhost:5432/myoflow && pnpm prisma:migrate:dev && pnpm --filter db seed"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.2.13",
    "prettier": "^3.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}