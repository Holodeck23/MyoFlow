      "@myoflow/ui": ["./packages/ui"],
      "@myoflow/lib": ["./packages/lib"],
      "@myoflow/db": ["./packages/db"]
    }
  },
  "include": ["next-env.d.ts"],
  "exclude": ["node_modules", ".next", "dist", "build"]
}