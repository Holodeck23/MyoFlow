generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  role      Role       @default(OWNER)
  createdAt DateTime   @default(now())
  Therapist Therapist?
}

model Therapist {
  id                    String                  @id @default(cuid())
  userId                String                  @unique
  slug                  String                  @unique
  designation           TherapistDesignation
  vatStatus             VatStatus
  kleinunternehmer      Boolean                 @default(true)
  annualGrossCents      Int                     @default(0)
  annualGrossCachedAt   DateTime?
  iban                  String?
  brandColor            String?
  logoUrl               String?
  createdAt             DateTime                @default(now())
  businessAddress       String?
  businessEmail         String?
  businessName          String?
  businessPhone         String?
  businessWebsite       String?
  chamberRegistration   String?
  defaultReminderDays   Int                     @default(1)
  enableEmailReminders  Boolean                 @default(true)
  enableSmsReminders    Boolean                 @default(false)
  invoiceFooter         String?
  profileCompletedAt    DateTime?
  uidNumber             String?
  updatedAt             DateTime                @default(now()) @updatedAt
  travelServiceRadius   Int?
  travelRatePerKm       Int?
  defaultTravelBuffer   Int                     @default(30)
  enableTravelService   Boolean                 @default(false)
  maxDailyTravelKm      Int?
  businessHours         Json?
  certificates          String[]                @default([])
  complianceSettings    Json?
  languagePreference    String                  @default("de")
  notificationSettings  Json?
  travelSettings        Json?
  profileCompletionScore Int                     @default(0) @map("profile_completion_score")
  settingsLastUpdated   DateTime?               @map("settings_last_updated")
  settingsVersion       Int                     @default(1) @map("settings_version")
  publicProfileSlug     String?                 @unique @map("public_profile_slug")
  publicProfileDescription String?             @map("public_profile_description")
  businessType          String?               @map("business_type")
  businessRegistrationNumber String?          @map("business_registration_number")
  taxAdvisorName        String?               @map("tax_advisor_name")
  taxAdvisorEmail       String?               @map("tax_advisor_email")
  taxAdvisorPhone       String?               @map("tax_advisor_phone")
  TaxComplianceSettings TaxComplianceSettings?
  travelSettingsDetail   TravelSettings?
  Preferences           UserPreferences?
  ExportConfigurations  ExportConfiguration[]
  Credentials           TherapistCredential[]
  Affiliates            Affiliate[]
  Appointments          Appointment[]
  AuditLogs             AuditLog[]
  BlockedTimes          BlockedTime[]
  BusinessConfiguration BusinessConfiguration[]
  BusinessHours         BusinessHours[]
  Clients               Client[]
  Consents              Consent[]
  Invoices              Invoice[]
  Locations             Location[]
  Notes                 Note[]
  Orders                Order[]
  Products              Product[]
  Services              Service[]
  ServiceRateTemplates  ServiceRateTemplate[]
  User                  User                    @relation(fields: [userId], references: [id])
  Vouchers              Voucher[]
}

model ServiceRateTemplate {
  id                 String          @id @default(cuid())
  therapistId        String
  name               String
  category           ServiceCategory
  durationMin        Int
  priceCents         Int
  vatRate            VatStatus
  description        String?
  isDefault          Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  isActive           Boolean         @default(true)
  isKleinunternehmer Boolean         @default(false)
  metadata           Json?
  travelRateCents    Int?
  pricingMode        PricingMode     @default(NET) @map("pricing_mode")
  travelIncluded     Boolean         @default(false) @map("travel_included")
  maxParticipants    Int?            @map("max_participants")
  defaultLocationId  String?         @map("default_location_id")
  bookingNotes       String?         @map("booking_notes")
  DefaultLocation    Location?       @relation("ServiceTemplateDefaultLocation", fields: [defaultLocationId], references: [id])
  Therapist          Therapist       @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, category, isActive])
  @@index([therapistId, isDefault])
}

model Location {
  id              String          @id @default(cuid())
  therapistId     String
  name            String
  type            LocationType
  address         String?
  travelBufferMin Int             @default(0)
  street          String?
  streetNumber    String?
  postalCode      String?
  city            String?
  state           String?
  country         String?         @default("Austria")
  latitude        Float?
  longitude       Float?
  geocodedAt      DateTime?
  isValidated     Boolean         @default(false)
  districtCode    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt
  DefaultForRates ServiceRateTemplate[] @relation("ServiceTemplateDefaultLocation")
  Appointments    Appointment[]
  BlockedTimes    BlockedTime[]
  BusinessHours   BusinessHours[]
  Therapist       Therapist       @relation(fields: [therapistId], references: [id])

  @@index([therapistId, type])
  @@index([postalCode, city])
}

model Client {
  id             String        @id @default(cuid())
  therapistId    String
  name           String
  email          String?
  phone          String?
  tags           String[]      @default([])
  healthFlagsEnc String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  street         String?
  postalCode     String?
  city           String?
  country        String?
  Appointments   Appointment[]
  Therapist      Therapist     @relation(fields: [therapistId], references: [id])
  Consents       Consent[]
  Invoices       Invoice[]
  Notes          Note[]

  @@index([therapistId, name])
}

model Service {
  id           String          @id @default(cuid())
  therapistId  String
  name         String
  category     ServiceCategory
  durationMin  Int
  priceCents   Int
  vatRate      VatStatus
  active       Boolean         @default(true)
  Appointments Appointment[]
  Therapist    Therapist       @relation(fields: [therapistId], references: [id])

  @@index([therapistId, category, active])
}

model Appointment {
  id                     String                @id @default(cuid())
  therapistId            String
  clientId               String
  serviceId              String
  locationId             String
  start                  DateTime
  end                    DateTime
  status                 AppointmentStatus     @default(BOOKED)
  notes                  String?
  createdAt              DateTime              @default(now())
  recurrenceEnd          DateTime?
  recurrenceId           String?
  recurrenceType         RecurrenceType        @default(NONE)
  updatedAt              DateTime              @updatedAt
  estimatedTravelTimeMin Int?
  travelDistanceKm       Float?
  travelCostCents        Int?
  requiresTravelBuffer   Boolean               @default(false)
  Client                 Client                @relation(fields: [clientId], references: [id])
  Location               Location              @relation(fields: [locationId], references: [id])
  Service                Service               @relation(fields: [serviceId], references: [id])
  Therapist              Therapist             @relation(fields: [therapistId], references: [id])
  Reminders              AppointmentReminder[]
  Invoice                Invoice?

  @@index([therapistId, start])
  @@index([therapistId, recurrenceId])
  @@index([therapistId, locationId, start])
}

model TherapistCredential {
  id                 String            @id @default(cuid())
  therapistId        String
  credentialType     CredentialType
  title              String
  issuingAuthority   String
  credentialNumber   String?
  specialization     String?
  issueDate          DateTime?
  expirationDate     DateTime?
  renewalRequired    Boolean          @default(false)
  status             CredentialStatus @default(ACTIVE)
  verificationUrl    String?
  verificationStatus CredentialVerificationStatus @default(UNVERIFIED)
  documentStorageKey String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  Therapist          Therapist        @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, credentialType])
  @@index([therapistId, status])
  @@index([therapistId, expirationDate])
  @@unique([therapistId, title])
}

model TravelSettings {
  id                       String          @id @default(cuid())
  therapistId              String          @unique @map("therapist_id")
  baseAddressLine1         String          @map("base_address_line1")
  baseAddressLine2         String?         @map("base_address_line2")
  baseCity                 String          @map("base_city")
  basePostalCode           String          @map("base_postal_code")
  baseState                String?         @map("base_state")
  baseCountry              String          @default("Austria") @map("base_country")
  latitude                 Float?
  longitude                Float?
  serviceRadiusKm          Int             @default(20) @map("service_radius_km")
  maximumTravelDistanceKm  Int?            @map("maximum_travel_distance_km")
  transportMethod          TransportMethod @default(CAR) @map("transport_method")
  ratePerKmCents           Int             @default(42) @map("rate_per_km_cents")
  minimumTravelChargeCents Int             @default(500) @map("minimum_travel_charge_cents")
  travelBufferMinutes      Int             @default(15) @map("travel_buffer_minutes")
  dailyTravelBudgetMinutes Int?            @map("daily_travel_budget_minutes")
  preferredTransportNotes  String?         @map("preferred_transport_notes")
  preferredRegions         String[]        @map("preferred_regions")
  excludedRegions          String[]        @map("excluded_regions")
  avoidHighways            Boolean         @default(false) @map("avoid_highways")
  avoidTolls               Boolean         @default(false) @map("avoid_tolls")
  realTimeTraffic          Boolean         @default(true) @map("real_time_traffic")
  backupTransportMethod    String?         @map("backup_transport_method")
  emergencyContactName     String?         @map("emergency_contact_name")
  emergencyContactPhone    String?         @map("emergency_contact_phone")
  createdAt                DateTime        @default(now()) @map("created_at")
  updatedAt                DateTime        @updatedAt @map("updated_at")
  Therapist                Therapist       @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId])
  @@index([basePostalCode, baseCity])
}

model TaxComplianceSettings {
  id                             String    @id @default(cuid())
  therapistId                    String    @unique @map("therapist_id")
  vatNumber                      String?   @map("vat_number")
  vatRegistered                  Boolean   @default(false) @map("vat_registered")
  kleinunternehmerActive         Boolean   @default(true) @map("kleinunternehmer_active")
  kleinunternehmerThresholdCents Int       @default(5500000) @map("kleinunternehmer_threshold_cents")
  currentYearRevenueCents        Int       @default(0) @map("current_year_revenue_cents")
  revenueYear                    Int?      @map("revenue_year")
  kleinunternehmerStart          DateTime? @map("kleinunternehmer_start")
  kleinunternehmerEnd            DateTime? @map("kleinunternehmer_end")
  legalNoticeTemplate            String?   @map("legal_notice_template")
  taxAdvisorName                 String?   @map("tax_advisor_name")
  taxAdvisorEmail                String?   @map("tax_advisor_email")
  taxAdvisorPhone                String?   @map("tax_advisor_phone")
  vatRegistrationDate            DateTime? @map("vat_registration_date")
  revenueLastCalculatedAt        DateTime? @map("revenue_last_calculated_at")
  rksvEnabled                    Boolean   @default(false) @map("rksv_enabled")
  cashRegisterId                 String?   @map("cash_register_id")
  signatureDeviceId              String?   @map("signature_device_id")
  rksvNotes                      String?   @map("rksv_notes")
  lastRksvAuditAt                DateTime? @map("last_rksv_audit_at")
  nextRksvAuditDue               DateTime? @map("next_rksv_audit_due")
  createdAt                      DateTime  @default(now()) @map("created_at")
  updatedAt                      DateTime  @updatedAt @map("updated_at")
  Therapist                      Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId])
  @@index([vatNumber])
}

model UserPreferences {
  id                       String    @id @default(cuid())
  therapistId              String    @unique @map("therapist_id")
  language                 Locale    @default(DE)
  timezone                 String    @default("Europe/Vienna")
  currency                 Currency  @default(EUR)
  dateFormat               String    @default("DD.MM.YYYY") @map("date_format")
  numberFormat             String    @default("1.234,56") @map("number_format")
  appointmentReminderDays  Int       @default(1) @map("appointment_reminder_days")
  enableEmailNotifications Boolean   @default(true) @map("enable_email_notifications")
  enableSmsNotifications   Boolean   @default(false) @map("enable_sms_notifications")
  enableComplianceAlerts   Boolean   @default(true) @map("enable_compliance_alerts")
  enableTravelAlerts       Boolean   @default(true) @map("enable_travel_alerts")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  Therapist                Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)
}

model ExportConfiguration {
  id                String               @id @default(cuid())
  therapistId       String
  exportType        ExportType
  targetSystem      ExportTargetSystem
  configurationName String
  description       String?
  isDefault         Boolean              @default(false)
  scheduleCron      String?
  fieldMappings     Json?
  lastRunAt         DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  Therapist         Therapist            @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, targetSystem])
  @@index([therapistId, isDefault])
  @@unique([therapistId, targetSystem, configurationName])
}

model BusinessHours {
  id          String    @id @default(cuid())
  therapistId String
  locationId  String?
  dayOfWeek   Int
  startTime   String
  endTime     String
  active      Boolean   @default(true)
  Location    Location? @relation(fields: [locationId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@unique([therapistId, locationId, dayOfWeek])
  @@index([therapistId, active])
}

model BlockedTime {
  id          String    @id @default(cuid())
  therapistId String
  locationId  String?
  start       DateTime
  end         DateTime
  type        BlockType
  title       String
  description String?
  active      Boolean   @default(true)
  Location    Location? @relation(fields: [locationId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, start, end])
}

model AppointmentReminder {
  id            String         @id @default(cuid())
  appointmentId String
  type          ReminderType
  status        ReminderStatus @default(PENDING)
  scheduledFor  DateTime
  sentAt        DateTime?
  errorMessage  String?
  Appointment   Appointment    @relation(fields: [appointmentId], references: [id])

  @@index([status, scheduledFor])
}

model AustrianHoliday {
  id          String              @id @default(cuid())
  name        String
  date        DateTime
  type        AustrianHolidayType
  year        Int
  stateCode   String?
  description String?
  active      Boolean             @default(true)

  @@unique([date, stateCode])
  @@index([year, active])
  @@index([stateCode, year])
}

model Invoice {
  id               String        @id @default(cuid())
  therapistId      String
  clientId         String?
  appointmentId    String?       @unique
  number           String        @unique
  status           InvoiceStatus @default(DRAFT)
  lines            Json
  totalGrossCents  Int
  vatBreakdown     Json
  kleinunternehmer Boolean
  pdfUrl           String?
  createdAt        DateTime      @default(now())
  Appointment      Appointment?  @relation(fields: [appointmentId], references: [id])
  Client           Client?       @relation(fields: [clientId], references: [id])
  Therapist        Therapist     @relation(fields: [therapistId], references: [id])
  Payments         Payment[]

  @@index([therapistId, createdAt])
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  provider    Provider
  amountCents Int
  status      PaymentStatus @default(PENDING)
  meta        Json?
  Invoice     Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId, status])
}

model Voucher {
  id                 String    @id @default(cuid())
  therapistId        String
  code               String    @unique
  balanceCents       Int
  expiresAt          DateTime?
  purchaserEmail     String?
  redeemedByClientId String?
  Therapist          Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

model Product {
  id          String      @id @default(cuid())
  therapistId String
  name        String
  type        ProductType
  priceCents  Int
  vatRate     VatStatus
  stock       Int?
  fileUrl     String?
  active      Boolean     @default(true)
  Orders      Order[]
  Therapist   Therapist   @relation(fields: [therapistId], references: [id])

  @@index([therapistId, active])
}

model Order {
  id                 String      @id @default(cuid())
  therapistId        String
  productId          String
  clientEmail        String
  amountCents        Int
  status             OrderStatus @default(PENDING)
  downloadToken      String?
  attributionRefCode String?
  createdAt          DateTime    @default(now())
  Product            Product     @relation(fields: [productId], references: [id])
  Therapist          Therapist   @relation(fields: [therapistId], references: [id])

  @@index([therapistId, status, createdAt])
}

model Consent {
  id          String    @id @default(cuid())
  therapistId String
  clientId    String
  docVersion  String
  acceptedAt  DateTime
  ip          String?
  payloadEnc  String
  Client      Client    @relation(fields: [clientId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, clientId, acceptedAt])
}

model Note {
  id          String    @id @default(cuid())
  therapistId String
  clientId    String
  bodyEnc     String
  createdAt   DateTime  @default(now())
  Client      Client    @relation(fields: [clientId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, clientId, createdAt])
}

model Affiliate {
  id               String    @id @default(cuid())
  refCode          String    @unique
  ownerTherapistId String
  percentBps       Int       @default(2000)
  active           Boolean   @default(true)
  Therapist        Therapist @relation(fields: [ownerTherapistId], references: [id])
}

model AuditLog {
  id          String    @id @default(cuid())
  actorUserId String?
  therapistId String
  entity      String
  entityId    String
  action      String
  at          DateTime  @default(now())
  ip          String?
  meta        Json?
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, entity, entityId, at])
}

model BusinessConfiguration {
  id          String    @id
  therapistId String
  configType  String
  configData  Json
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, configType])
  @@index([therapistId, configType])
}

enum Role {
  OWNER
  STAFF
  ACCOUNTANT
  AFFILIATE
}

enum TherapistDesignation {
  HEILMASSEUR
  MEDIZINISCHER_MASSEUR
  GEWERBLICHER_MASSEUR
}

enum VatStatus {
  KLEINUNTERNEHMER
  UST_10
  UST_13
  UST_20
}

enum PricingMode {
  NET
  GROSS
}

enum CredentialType {
  PROFESSIONAL_LICENSE
  CERTIFICATION
  QUALIFICATION
  CONTINUING_EDUCATION
  SPECIALIZATION
  INSURANCE_APPROVAL
}

enum CredentialStatus {
  ACTIVE
  EXPIRING
  EXPIRED
  SUSPENDED
  PENDING
}

enum CredentialVerificationStatus {
  VERIFIED
  UNVERIFIED
  PENDING
}

enum TransportMethod {
  CAR
  PUBLIC_TRANSPORT
  BICYCLE
  WALKING
  MOTORCYCLE
}

enum Locale {
  DE
  EN
}

enum Currency {
  EUR
}

enum ExportType {
  ACCOUNTING_EXPORT
  DATA_BACKUP
  CUSTOM_REPORT
}

enum ExportTargetSystem {
  BMD
  RZL
  DATEV
  CSV_GENERIC
  CUSTOM
}

enum LocationType {
  HOME
  CLINIC
  MOBILE
  CLUB
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RecurrenceType {
  NONE
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum BlockType {
  HOLIDAY
  VACATION
  BREAK
  MAINTENANCE
}

enum AustrianHolidayType {
  NATIONAL
  REGIONAL
  RELIGIOUS
  COMMEMORATION
}

enum ReminderType {
  EMAIL
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum Provider {
  STRIPE
  MANUAL
}

enum PaymentStatus {
  PENDING
  SETTLED
  FAILED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
}

enum ServiceCategory {
  MASSAGE
  YOGA
  CONSULTING
  OTHER
}
