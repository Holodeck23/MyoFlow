generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  role      Role       @default(OWNER)
  createdAt DateTime   @default(now())
  Therapist Therapist?
}

model Therapist {
  id                    String                  @id @default(cuid())
  userId                String                  @unique
  slug                  String                  @unique
  designation           TherapistDesignation
  vatStatus             VatStatus
  kleinunternehmer      Boolean                 @default(true)
  annualGrossCents      Int                     @default(0)
  annualGrossCachedAt   DateTime?
  iban                  String?
  brandColor            String?
  logoUrl               String?
  createdAt             DateTime                @default(now())
  businessAddress       String?
  businessEmail         String?
  businessName          String?
  businessPhone         String?
  businessWebsite       String?
  chamberRegistration   String?
  defaultReminderDays   Int                     @default(1)
  enableEmailReminders  Boolean                 @default(true)
  enableSmsReminders    Boolean                 @default(false)
  invoiceFooter         String?
  profileCompletedAt    DateTime?
  uidNumber             String?
  updatedAt             DateTime                @default(now()) @updatedAt
  travelServiceRadius   Int?
  travelRatePerKm       Int?
  defaultTravelBuffer   Int                     @default(30)
  enableTravelService   Boolean                 @default(false)
  maxDailyTravelKm      Int?
  businessHours         Json?
  certificates          String[]                @default([])
  complianceSettings    Json?
  languagePreference    String                  @default("de")
  notificationSettings  Json?
  travelSettings        Json?
  Affiliates            Affiliate[]
  Appointments          Appointment[]
  AuditLogs             AuditLog[]
  BlockedTimes          BlockedTime[]
  BusinessConfiguration BusinessConfiguration[]
  BusinessHours         BusinessHours[]
  Clients               Client[]
  Consents              Consent[]
  Invoices              Invoice[]
  Locations             Location[]
  Notes                 Note[]
  Orders                Order[]
  Products              Product[]
  Services              Service[]
  ServiceRateTemplates  ServiceRateTemplate[]
  User                  User                    @relation(fields: [userId], references: [id])
  Vouchers              Voucher[]
}

model ServiceRateTemplate {
  id                 String          @id @default(cuid())
  therapistId        String
  name               String
  category           ServiceCategory
  durationMin        Int
  priceCents         Int
  vatRate            VatStatus
  description        String?
  isDefault          Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  isActive           Boolean         @default(true)
  isKleinunternehmer Boolean         @default(false)
  metadata           Json?
  travelRateCents    Int?
  Therapist          Therapist       @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@index([therapistId, category, isActive])
  @@index([therapistId, isDefault])
}

model Location {
  id              String          @id @default(cuid())
  therapistId     String
  name            String
  type            LocationType
  address         String?
  travelBufferMin Int             @default(0)
  street          String?
  streetNumber    String?
  postalCode      String?
  city            String?
  state           String?
  country         String?         @default("Austria")
  latitude        Float?
  longitude       Float?
  geocodedAt      DateTime?
  isValidated     Boolean         @default(false)
  districtCode    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @default(now()) @updatedAt
  Appointments    Appointment[]
  BlockedTimes    BlockedTime[]
  BusinessHours   BusinessHours[]
  Therapist       Therapist       @relation(fields: [therapistId], references: [id])

  @@index([therapistId, type])
  @@index([postalCode, city])
}

model Client {
  id             String        @id @default(cuid())
  therapistId    String
  name           String
  email          String?
  phone          String?
  tags           String[]      @default([])
  healthFlagsEnc String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  street         String?
  postalCode     String?
  city           String?
  country        String?
  Appointments   Appointment[]
  Therapist      Therapist     @relation(fields: [therapistId], references: [id])
  Consents       Consent[]
  Invoices       Invoice[]
  Notes          Note[]

  @@index([therapistId, name])
}

model Service {
  id           String          @id @default(cuid())
  therapistId  String
  name         String
  category     ServiceCategory
  durationMin  Int
  priceCents   Int
  vatRate      VatStatus
  active       Boolean         @default(true)
  Appointments Appointment[]
  Therapist    Therapist       @relation(fields: [therapistId], references: [id])

  @@index([therapistId, category, active])
}

model Appointment {
  id                     String                @id @default(cuid())
  therapistId            String
  clientId               String
  serviceId              String
  locationId             String
  start                  DateTime
  end                    DateTime
  status                 AppointmentStatus     @default(BOOKED)
  notes                  String?
  createdAt              DateTime              @default(now())
  recurrenceEnd          DateTime?
  recurrenceId           String?
  recurrenceType         RecurrenceType        @default(NONE)
  updatedAt              DateTime              @updatedAt
  estimatedTravelTimeMin Int?
  travelDistanceKm       Float?
  travelCostCents        Int?
  requiresTravelBuffer   Boolean               @default(false)
  Client                 Client                @relation(fields: [clientId], references: [id])
  Location               Location              @relation(fields: [locationId], references: [id])
  Service                Service               @relation(fields: [serviceId], references: [id])
  Therapist              Therapist             @relation(fields: [therapistId], references: [id])
  Reminders              AppointmentReminder[]
  Invoice                Invoice?

  @@index([therapistId, start])
  @@index([therapistId, recurrenceId])
  @@index([therapistId, locationId, start])
}

model BusinessHours {
  id          String    @id @default(cuid())
  therapistId String
  locationId  String?
  dayOfWeek   Int
  startTime   String
  endTime     String
  active      Boolean   @default(true)
  Location    Location? @relation(fields: [locationId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@unique([therapistId, locationId, dayOfWeek])
  @@index([therapistId, active])
}

model BlockedTime {
  id          String    @id @default(cuid())
  therapistId String
  locationId  String?
  start       DateTime
  end         DateTime
  type        BlockType
  title       String
  description String?
  active      Boolean   @default(true)
  Location    Location? @relation(fields: [locationId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, start, end])
}

model AppointmentReminder {
  id            String         @id @default(cuid())
  appointmentId String
  type          ReminderType
  status        ReminderStatus @default(PENDING)
  scheduledFor  DateTime
  sentAt        DateTime?
  errorMessage  String?
  Appointment   Appointment    @relation(fields: [appointmentId], references: [id])

  @@index([status, scheduledFor])
}

model AustrianHoliday {
  id          String              @id @default(cuid())
  name        String
  date        DateTime
  type        AustrianHolidayType
  year        Int
  stateCode   String?
  description String?
  active      Boolean             @default(true)

  @@unique([date, stateCode])
  @@index([year, active])
  @@index([stateCode, year])
}

model Invoice {
  id               String        @id @default(cuid())
  therapistId      String
  clientId         String?
  appointmentId    String?       @unique
  number           String        @unique
  status           InvoiceStatus @default(DRAFT)
  lines            Json
  totalGrossCents  Int
  vatBreakdown     Json
  kleinunternehmer Boolean
  pdfUrl           String?
  createdAt        DateTime      @default(now())
  Appointment      Appointment?  @relation(fields: [appointmentId], references: [id])
  Client           Client?       @relation(fields: [clientId], references: [id])
  Therapist        Therapist     @relation(fields: [therapistId], references: [id])
  Payments         Payment[]

  @@index([therapistId, createdAt])
}

model Payment {
  id          String        @id @default(cuid())
  invoiceId   String
  provider    Provider
  amountCents Int
  status      PaymentStatus @default(PENDING)
  meta        Json?
  Invoice     Invoice       @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId, status])
}

model Voucher {
  id                 String    @id @default(cuid())
  therapistId        String
  code               String    @unique
  balanceCents       Int
  expiresAt          DateTime?
  purchaserEmail     String?
  redeemedByClientId String?
  Therapist          Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId])
}

model Product {
  id          String      @id @default(cuid())
  therapistId String
  name        String
  type        ProductType
  priceCents  Int
  vatRate     VatStatus
  stock       Int?
  fileUrl     String?
  active      Boolean     @default(true)
  Orders      Order[]
  Therapist   Therapist   @relation(fields: [therapistId], references: [id])

  @@index([therapistId, active])
}

model Order {
  id                 String      @id @default(cuid())
  therapistId        String
  productId          String
  clientEmail        String
  amountCents        Int
  status             OrderStatus @default(PENDING)
  downloadToken      String?
  attributionRefCode String?
  createdAt          DateTime    @default(now())
  Product            Product     @relation(fields: [productId], references: [id])
  Therapist          Therapist   @relation(fields: [therapistId], references: [id])

  @@index([therapistId, status, createdAt])
}

model Consent {
  id          String    @id @default(cuid())
  therapistId String
  clientId    String
  docVersion  String
  acceptedAt  DateTime
  ip          String?
  payloadEnc  String
  Client      Client    @relation(fields: [clientId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, clientId, acceptedAt])
}

model Note {
  id          String    @id @default(cuid())
  therapistId String
  clientId    String
  bodyEnc     String
  createdAt   DateTime  @default(now())
  Client      Client    @relation(fields: [clientId], references: [id])
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, clientId, createdAt])
}

model Affiliate {
  id               String    @id @default(cuid())
  refCode          String    @unique
  ownerTherapistId String
  percentBps       Int       @default(2000)
  active           Boolean   @default(true)
  Therapist        Therapist @relation(fields: [ownerTherapistId], references: [id])
}

model AuditLog {
  id          String    @id @default(cuid())
  actorUserId String?
  therapistId String
  entity      String
  entityId    String
  action      String
  at          DateTime  @default(now())
  ip          String?
  meta        Json?
  Therapist   Therapist @relation(fields: [therapistId], references: [id])

  @@index([therapistId, entity, entityId, at])
}

model BusinessConfiguration {
  id          String    @id
  therapistId String
  configType  String
  configData  Json
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Therapist   Therapist @relation(fields: [therapistId], references: [id], onDelete: Cascade)

  @@unique([therapistId, configType])
  @@index([therapistId, configType])
}

enum Role {
  OWNER
  STAFF
  ACCOUNTANT
  AFFILIATE
}

enum TherapistDesignation {
  HEILMASSEUR
  MEDIZINISCHER_MASSEUR
  GEWERBLICHER_MASSEUR
}

enum VatStatus {
  KLEINUNTERNEHMER
  UST_10
  UST_13
  UST_20
}

enum LocationType {
  HOME
  CLINIC
  MOBILE
  CLUB
}

enum AppointmentStatus {
  BOOKED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum RecurrenceType {
  NONE
  WEEKLY
  BIWEEKLY
  MONTHLY
}

enum BlockType {
  HOLIDAY
  VACATION
  BREAK
  MAINTENANCE
}

enum AustrianHolidayType {
  NATIONAL
  REGIONAL
  RELIGIOUS
  COMMEMORATION
}

enum ReminderType {
  EMAIL
  SMS
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ProductType {
  PHYSICAL
  DIGITAL
}

enum Provider {
  STRIPE
  MANUAL
}

enum PaymentStatus {
  PENDING
  SETTLED
  FAILED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
}

enum OrderStatus {
  PENDING
  PAID
  REFUNDED
}

enum ServiceCategory {
  MASSAGE
  YOGA
  CONSULTING
  OTHER
}
