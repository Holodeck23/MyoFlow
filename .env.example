# App
APP_BASE_URL=http://localhost:3000
NODE_ENV=development

# Database / Queue
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/myoflow
REDIS_URL=redis://localhost:6379

# Auth
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=change-me-to-a-secure-random-string-min-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
EMAIL_SERVER_HOST=
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=MyoFlow <noreply@myoflow.local>
# Enable demo/test auth shortcuts in development (never enable in production)
AUTH_ENABLE_DEMO=false

# Admin Authentication (REQUIRED - min 32 characters)
# Generate with: openssl rand -base64 32
ADMIN_JWT_SECRET=

# Crypto (REQUIRED for client data encryption)
# Generate encryption key with: openssl rand -base64 32
# ENCRYPTION_KEY_B64 - Used for encrypting sensitive client data (health flags, notes, etc.)
# ENCRYPTION_KEY - Legacy field, can be left empty
# INTAKE_TOKEN_SECRET - Generate with: openssl rand -base64 32
ENCRYPTION_KEY_B64=
ENCRYPTION_KEY=
INTAKE_TOKEN_SECRET=

# Messaging
RESEND_API_KEY=
VONAGE_API_KEY=
VONAGE_API_SECRET=

# Payments
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Analytics (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com
POSTHOG_ENABLED=false

# File uploads
UPLOAD_MAX_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp,application/pdf

# Google Maps for travel calculations
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
